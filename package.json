{
  "name": "@loongphy/codex-auth",
  "version": "0.2.3-alpha.3",
  "description": "CLI for switching Codex accounts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Loongphy/codex-auth"
  },
  "homepage": "https://github.com/Loongphy/codex-auth",
  "bugs": {
    "url": "https://github.com/Loongphy/codex-auth/issues"
  },
  "bin": {
    "codex-auth": "bin/codex-auth.js"
  },
  "files": [
    "bin/",
    "LICENSE",
    "README.md"
  ],
  "optionalDependencies": {
    "@loongphy/codex-auth-linux-x64": "0.2.3-alpha.3",
    "@loongphy/codex-auth-darwin-x64": "0.2.3-alpha.3",
    "@loongphy/codex-auth-darwin-arm64": "0.2.3-alpha.3",
    "@loongphy/codex-auth-win32-x64": "0.2.3-alpha.3",
    "@loongphy/codex-auth-win32-arm64": "0.2.3-alpha.3"
  },
  "scripts": {
    "check:versions": "node scripts/npm/check-versions.mjs",
    "stage:npm": "node scripts/npm/stage-packages.mjs",
    "check:release-host": "node scripts/npm/validate-release-host.mjs",
    "check:release-hygiene": "node scripts/verify-release-hygiene.mjs",
    "desktop:install": "npm --prefix apps/codex-auth-desktop install",
    "desktop:test": "npm --prefix apps/codex-auth-desktop run test:ui",
    "desktop:check": "npm --prefix apps/codex-auth-desktop run check",
    "desktop:audit": "npm --prefix apps/codex-auth-desktop run audit",
    "desktop:dev": "npm --prefix apps/codex-auth-desktop run tauri:dev --",
    "desktop:run": "npm --prefix apps/codex-auth-desktop run run:local",
    "desktop:build": "npm --prefix apps/codex-auth-desktop run tauri:build --",
    "desktop:linux:check": "npm --prefix apps/codex-auth-desktop run linux:check",
    "desktop:linux:package": "npm --prefix apps/codex-auth-desktop run linux:package",
    "desktop:linux:install": "npm --prefix apps/codex-auth-desktop run linux:install",
    "desktop:linux:uninstall": "npm --prefix apps/codex-auth-desktop run linux:uninstall",
    "desktop:windows:check": "npm --prefix apps/codex-auth-desktop run windows:check",
    "desktop:windows:package": "npm --prefix apps/codex-auth-desktop run windows:package"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
